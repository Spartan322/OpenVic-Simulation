{
    "base_branches": [
        "master"
    ],
    "tag_resolver": {
        "method": "sort",
        "filter": {
            "method": "regexr",
            "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha|beta|rc)\\.(\\d+)))?"
        }
    },
    "custom_placeholders": [
        {
            "name": "UPCOMING_RELEASE_VERSION",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha|beta|rc)\\.(\\d+)))?",
                "target": "$1"
            }
        },
        {
            "name": "PRE_RELEASE_VERSION",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha|beta|rc)\\.(\\d+)))?",
                "target": "$4"
            }
        },
        {
            "name": "ALPHA_TAG",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha)\\.(\\d+)))",
                "target": " Alpha "
            }
        },
        {
            "name": "BETA_TAG",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((beta)\\.(\\d+)))",
                "target": " Beta "
            }
        },
        {
            "name": "RC_TAG",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((rc)\\.(\\d+)))",
                "target": " Release Candidate "
            }
        },
        {
            "name": "SINCE_VERSION",
            "source": "FROM_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha|beta|rc)\\.(\\d+)))?",
                "target": "$1-$3.$4"
            }
        }
    ],
    "categories": [
        {
            "title": "### Enhancements & Features",
            "labels": [
                "enhancement"
            ],
            "exhaustive": true,
            "consume": true
        },
        {
            "title": "### Bug Fixes",
            "labels": [
                "bug"
            ],
            "exhaustive": true,
            "consume": true
        }
    ],
    "template": "## Release Notes for OpenVic-Simulation #{{UPCOMING_RELEASE_VERSION}}#{{ALPHA_TAG}}#{{BETA_TAG}}#{{RC_TAG}} #{{PRE_RELEASE_VERSION}}\n### Changelog since [#{{SINCE_VERSION}}](https://github.com/username/repo/releases/tag/#{{SINCE_VERSION}})\n#{{CHANGELOG}}\n**Full Changelog**: #{{RELEASE_DIFF}}",
    "pr_template": "* #{{TITLE}} by @#{{AUTHOR}} in #{{URL}}",
    "max_pull_requests": 1000,
    "max_back_track_time_days": 365
}