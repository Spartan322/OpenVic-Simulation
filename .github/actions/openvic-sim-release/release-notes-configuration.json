{
    "base_branches": [
        "master"
    ],
    "tag_resolver": {
        "method": "sort",
        "filter": {
            "method": "regexr",
            "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha|beta|rc)\\.(\\d+)))?"
        }
    },
    "custom_placeholders": [
        {
            "name": "RELEASE_VERSION",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha|beta|rc)\\.(\\d+)))?",
                "target": "$1 <<capitalize:$3>> $4"
            }
        },
        {
            "name": "SINCE_VERSION",
            "source": "FROM_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((alpha|beta|rc)\\.(\\d+)))?",
                "target": "$&"
            }
        }
    ],
    "categories": [
        {
            "title": "### Enhancements & Features",
            "labels": [
                "enhancement"
            ],
            "exhaustive": true,
            "consume": true
        },
        {
            "title": "### Bug Fixes",
            "labels": [
                "bug"
            ],
            "exhaustive": true,
            "consume": true
        }
    ],
    "template": "## Release Notes for <<REPO_NAME>> #{{RELEASE_VERSION}}\n### Changelog since [#{{SINCE_VERSION}}](https://github.com/<<REPO>>/releases/tag/#{{SINCE_VERSION}})\n#{{CHANGELOG}}\n\n**Full Changelog**: #{{RELEASE_DIFF}}",
    "empty_template": "## Release Notes for <<REPO_NAME>> #{{RELEASE_VERSION}}\n### No Pull Requests since [#{{SINCE_VERSION}}](https://github.com/<<REPO>>/releases/tag/#{{SINCE_VERSION}})\n\n**Full Changelog**: #{{RELEASE_DIFF}}",
    "pr_template": "* #{{TITLE}} by @#{{AUTHOR}} in #{{URL}}",
    "max_pull_requests": 1000,
    "max_back_track_time_days": 365
}