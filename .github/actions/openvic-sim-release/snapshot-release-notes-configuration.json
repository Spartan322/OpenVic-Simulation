{
    "base_branches": [
        "master"
    ],
    "custom_placeholders": [
        {
            "name": "UPCOMING_RELEASE_VERSION",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((?:((snapshot(?:\\.(dev))?)\\.(\\d+)))\\+([a-zA-Z0-9]{7,40})))",
                "target": "$1"
            }
        },
        {
            "name": "DEV_TAG",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((?:((snapshot(?:\\.(dev))?)\\.(\\d+)))\\+([a-zA-Z0-9]{7,40})))",
                "target": " Dev"
            }
        },
        {
            "name": "PRE_RELEASE_VERSION",
            "source": "TO_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-((?:((snapshot(?:\\.(dev))?)\\.(\\d+)))\\+([a-zA-Z0-9]{7,40})))",
                "target": "$6"
            }
        },
        {
            "name": "SINCE_VERSION",
            "source": "FROM_TAG",
            "transformer": {
                "method": "regexr",
                "pattern": "(\\d+\\.\\d+(?:\\.\\d+)?)(?:-(((alpha|beta|rc)\\.(\\d+))|(?:(?:((snapshot)(?:\\.(dev))?)\\.(\\d+))\\+([a-zA-Z0-9]{7,40}))))?",
                "target": "$&"
            }
        }
    ],
    "categories": [
        {
            "title": "### Enhancements & Features",
            "labels": [
                "enhancement"
            ],
            "exhaustive": true,
            "consume": true
        },
        {
            "title": "### Bug Fixes",
            "labels": [
                "bug"
            ],
            "exhaustive": true,
            "consume": true
        }
    ],
    "template": "## Release Notes for OpenVic-Simulation #{{UPCOMING_RELEASE_VERSION}}#{{DEV_TAG}} Snapshot #{{PRE_RELEASE_VERSION}}\n### Changelog since [#{{SINCE_VERSION}}](https://github.com/username/repo/releases/tag/#{{SINCE_VERSION}})\n#{{CHANGELOG}}\n**Full Changelog**: #{{RELEASE_DIFF}}",
    "pr_template": "* #{{TITLE}} by @#{{AUTHOR}} in #{{URL}}",
    "max_pull_requests": 1000,
    "max_back_track_time_days": 365
}